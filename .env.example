# Zabbix API Configuration
ZABBIX_URL=https://your-zabbix-server.com/zabbix/api_jsonrpc.php
# Use API token for authentication (recommended)
ZABBIX_API_TOKEN=your_api_token_here
# Or use username/password (legacy method)
# ZABBIX_USER=your_username
# ZABBIX_PASSWORD=your_password

# SSL/TLS Configuration
ZABBIX_VERIFY_SSL=true

# Read-Only Mode Configuration
# When set to true, all write operations (create, update, delete) will be blocked
ZABBIX_READONLY=false

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SESSION_TIMEOUT=3600
